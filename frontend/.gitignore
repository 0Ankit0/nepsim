# =============================================================================
# Frontend .gitignore — Next.js 16 / TypeScript / TailwindCSS v4 / bun / Husky
# =============================================================================

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Build Output ────────────────────────────────────────────────────────────
build/
dist/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local
!.env.example
!.env.template

# ─── Testing & Coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Package Manager Locks (keep bun.lock, ignore competing managers) ─────────
# bun.lock is intentionally tracked
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Debug Logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
*.log

# ─── Linting & Formatting Cache ──────────────────────────────────────────────
.eslintcache
.stylelintcache
.prettiercache

# ─── Vercel / Deployment ─────────────────────────────────────────────────────
.vercel
.netlify

# ─── Storybook ───────────────────────────────────────────────────────────────
storybook-static/

# ─── Sentry ──────────────────────────────────────────────────────────────────
.sentryclirc

# ─── OS & Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json

# ─── SonarQube ───────────────────────────────────────────────────────────────
.scannerwork/

# ─── Certificates ────────────────────────────────────────────────────────────
*.pem
*.key
