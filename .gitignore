# =============================================================================
# NEPSIM Monorepo — Root .gitignore
# Covers: backend (Python/FastAPI/uv), frontend (Next.js/TypeScript), mobile (Flutter)
# =============================================================================

# ─── OS & Editor ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains IDEs (IntelliJ, PyCharm, Android Studio, etc.)
.idea/
*.iml
*.ipr
*.iws
*.eml

# VS Code
.vscode/
*.code-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
*~

# Emacs
\#*\#
.\#*

# ─── Secrets & Environment ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
!.env.example
!.env.template

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# ─── Certificates & Keys ─────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer

# ─── Data & ML Artifacts (project-specific) ──────────────────────────────────
data/raw/
data/processed/
experiments/
mlruns/
*.parquet
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.safetensors

# ─── Docker ──────────────────────────────────────────────────────────────────
# (Keep Dockerfiles tracked; ignore local overrides)
docker-compose.override.yml

# ─── Temporary / Build artifacts ─────────────────────────────────────────────
tmp/
temp/
dist/
build/
out/
