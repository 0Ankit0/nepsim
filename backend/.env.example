PYTHONPATH=.
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nepsim
ACCESS_TOKEN_EXPIRE_MINUTES=11520
SECRET_KEY=change-this-in-production
DEBUG=True

# Redis settings (only used in production when DEBUG=False)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password
REDIS_MAX_CONNECTIONS=10

# Email settings
EMAIL_ENABLED=False
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=password
EMAIL_FROM_ADDRESS=noreply@nepsim.app

# ── NEPSIM AI Analysis ─────────────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# NEPSE historical data CSV directory (for seed script)
NEPSE_DATA_PATH=data/nepse_ohlcv

# ── Payments (disabled for local dev) ─────────────────────────────────────
KHALTI_ENABLED=False
ESEWA_ENABLED=False
STRIPE_ENABLED=False
PAYPAL_ENABLED=False