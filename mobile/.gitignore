# =============================================================================
# Mobile .gitignore — Flutter / Dart / Riverpod / build_runner / freezed
# =============================================================================

# ─── Flutter / Dart / Pub ────────────────────────────────────────────────────
.dart_tool/
.pub-cache/
.pub/
.flutter-plugins
.flutter-plugins-dependencies
# pubspec.lock is intentionally tracked for reproducibility

# ─── Build Output ────────────────────────────────────────────────────────────
build/
/coverage/

# ─── Generated Code (build_runner, freezed, json_serializable, riverpod) ─────
# Uncomment lines below to ignore generated files if you prefer not to track them.
# *.g.dart
# *.freezed.dart
# *.gr.dart
# For this project: we track generated dart files for CI reproducibility

# ─── Environment ─────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
!.env.example

# ─── IntelliJ / Android Studio ───────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws

# ─── VS Code ─────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json

# ─── Xcode (iOS / macOS) ─────────────────────────────────────────────────────
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/ios/.symlinks/
**/macos/Pods/
**/macos/.symlinks/
**/ios/*.xcworkspace/xcuserdata/
**/macos/*.xcworkspace/xcuserdata/
**/ios/Runner/GeneratedPluginRegistrant.*
xcuserdata/
*.xcscmblueprint
*.xccheckout
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ─── Android ─────────────────────────────────────────────────────────────────
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/local.properties
**/android/key.properties
*.keystore
*.jks
google-services.json
!**/android/google-services.json.example

# ─── Firebase ────────────────────────────────────────────────────────────────
GoogleService-Info.plist
!**/ios/GoogleService-Info.plist.example
google-services.json
!**/android/google-services.json.example
firebase_options.dart

# ─── Symbolication & Obfuscation ─────────────────────────────────────────────
app.*.symbols
app.*.map.json

# ─── Test Coverage ───────────────────────────────────────────────────────────
coverage/

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.log

# ─── Miscellaneous ───────────────────────────────────────────────────────────
migrate_working_dir/
*.class
*.pyc
.history/
